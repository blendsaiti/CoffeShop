@model Microsoft.AspNetCore.Identity.IdentityUser
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="ud-page-header">
    <div class="ud-eyebrow">Account</div>
    <h1 class="ud-title">My <em>Profile</em></h1>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:22px;">

    <!-- Profile Info -->
    <div class="ud-panel">
        <div class="ud-panel-header">
            <div class="ud-panel-title-grp">
                <div class="ud-panel-icon"><i class="fas fa-user"></i></div>
                <span class="ud-panel-title">Account Details</span>
            </div>
        </div>
        <div class="ud-panel-body">
            <!-- Avatar -->
            <div style="display:flex;align-items:center;gap:18px;padding-bottom:20px;margin-bottom:20px;border-bottom:1px solid var(--border);">
                <div style="width:64px;height:64px;border-radius:50%;background:var(--espresso);border:1.5px solid rgba(181,117,42,0.3);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:var(--latte);flex-shrink:0;">
                    @Model.UserName.Substring(0, 1).ToUpper()
                </div>
                <div>
                    <div style="font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:var(--espresso);">@Model.UserName</div>
                    <div style="font-size:12px;color:var(--muted);margin-top:3px;">Member Account</div>
                </div>
            </div>

            <!-- Info rows -->
            @{
                void InfoRow(string label, string value, string? badgeText = null, string? badgeCls = null)
                {
                    <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid rgba(181,117,42,0.06);">
                        <span style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);">@label</span>
                        <div style="display:flex;align-items:center;gap:8px;">
                            <span style="font-size:13px;font-weight:500;color:var(--espresso);">@value</span>
                            @if (badgeText != null)
                            {
                                <span class="s-badge @badgeCls">@badgeText</span>
                            }
                        </div>
                    </div>
                ;
                }
            }
            @{
                InfoRow("Username", Model.UserName);
            }
            @{
                InfoRow("Email", Model.Email, Model.EmailConfirmed ? "Verified" : "Unverified", Model.EmailConfirmed ? "verified" : "unverified");
            }
            @{
                InfoRow("Phone", string.IsNullOrEmpty(Model.PhoneNumber) ? "Not provided" : Model.PhoneNumber);
            }
        </div>
    </div>

    <!-- Account Settings -->
    <div class="ud-panel">
        <div class="ud-panel-header">
            <div class="ud-panel-title-grp">
                <div class="ud-panel-icon"><i class="fas fa-cog"></i></div>
                <span class="ud-panel-title">Account Settings</span>
            </div>
        </div>
        <div class="ud-panel-body">
            <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:28px;">
                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="u-btn u-btn-primary" style="justify-content:center;">
                    <i class="fas fa-user-edit"></i> Edit Profile
                </a>
                <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="u-btn u-btn-outline" style="justify-content:center;">
                    <i class="fas fa-lock"></i> Change Password
                </a>
                <a asp-area="Identity" asp-page="/Account/Manage/Email" class="u-btn u-btn-outline" style="justify-content:center;">
                    <i class="fas fa-envelope"></i> Change Email
                </a>
            </div>

            <div style="border-top:1px solid var(--border);padding-top:20px;">
                <div style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:14px;">Quick Navigation</div>
                <div style="display:flex;flex-direction:column;gap:8px;">
                    <a asp-action="OrderHistory" style="display:flex;align-items:center;gap:9px;font-size:13px;color:var(--espresso);text-decoration:none;padding:8px 0;border-bottom:1px solid rgba(181,117,42,0.06);">
                        <i class="fas fa-receipt" style="color:var(--caramel);width:16px;font-size:12px;"></i> Order History
                    </a>
                    <a asp-action="MyReviews" style="display:flex;align-items:center;gap:9px;font-size:13px;color:var(--espresso);text-decoration:none;padding:8px 0;border-bottom:1px solid rgba(181,117,42,0.06);">
                        <i class="fas fa-star" style="color:var(--caramel);width:16px;font-size:12px;"></i> My Reviews
                    </a>
                    <a asp-action="Addresses" style="display:flex;align-items:center;gap:9px;font-size:13px;color:var(--espresso);text-decoration:none;padding:8px 0;">
                        <i class="fas fa-map-marker-alt" style="color:var(--caramel);width:16px;font-size:12px;"></i> My Addresses
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
