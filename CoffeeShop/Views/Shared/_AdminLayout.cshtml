<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/bootstrap/css/bootstrap.min.css">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --espresso:   #1c0f08;
            --roast:      #2e1810;
            --sidebar-w:  240px;
            --caramel:    #b5752a;
            --latte:      #d4a96a;
            --cream:      #f5ede0;
            --foam:       #faf6f0;
            --bg:         #f3f0ec;
            --surface:    #ffffff;
            --border:     rgba(181,117,42,0.12);
            --text:       #1c0f08;
            --muted:      #7a6a5a;
            --warm-grey:  #7a6a5a;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
        }

        /* ── SIDEBAR ───────────────────────────────────────── */
        .admin-sidebar {
            position: fixed;
            left: 0; top: 0;
            height: 100vh;
            width: var(--sidebar-w);
            background: var(--espresso);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .admin-sidebar::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23b5752a' fill-opacity='0.04'%3E%3Ccircle cx='20' cy='20' r='1'/%3E%3C/g%3E%3C/svg%3E");
            pointer-events: none;
        }

        .sidebar-brand {
            padding: 28px 24px 24px;
            border-bottom: 1px solid rgba(181,117,42,0.12);
            flex-shrink: 0;
            position: relative;
            z-index: 1;
        }
        .sidebar-brand-logo {
            display: flex;
            align-items: center;
            gap: 11px;
            text-decoration: none;
            margin-bottom: 4px;
        }
        .brand-icon {
            width: 34px; height: 34px;
            border-radius: 50%;
            border: 1px solid rgba(181,117,42,0.35);
            display: flex; align-items: center; justify-content: center;
            color: var(--latte);
            font-size: 15px;
            flex-shrink: 0;
        }
        .brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 17px;
            font-weight: 700;
            color: var(--cream);
            letter-spacing: 0.3px;
        }
        .brand-role {
            font-size: 10px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(212,169,106,0.45);
            padding-left: 45px;
        }

        /* Nav */
        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 20px 0;
            position: relative;
            z-index: 1;
        }
        .sidebar-nav::-webkit-scrollbar { width: 3px; }
        .sidebar-nav::-webkit-scrollbar-track { background: transparent; }
        .sidebar-nav::-webkit-scrollbar-thumb { background: rgba(181,117,42,0.2); border-radius: 2px; }

        .nav-section-label {
            font-size: 9px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(212,169,106,0.35);
            padding: 16px 24px 8px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 24px;
            color: rgba(245,237,224,0.5);
            text-decoration: none;
            font-size: 13px;
            font-weight: 400;
            letter-spacing: 0.3px;
            border-left: 2px solid transparent;
            transition: all 0.2s;
            position: relative;
        }
        .nav-link i {
            width: 18px;
            font-size: 14px;
            text-align: center;
            flex-shrink: 0;
            opacity: 0.7;
        }
        .nav-link:hover {
            color: var(--cream);
            background: rgba(255,255,255,0.04);
            border-left-color: rgba(181,117,42,0.4);
        }
        .nav-link:hover i { opacity: 1; }
        .nav-link.active {
            color: var(--latte);
            background: rgba(181,117,42,0.1);
            border-left-color: var(--caramel);
            font-weight: 500;
        }
        .nav-link.active i { opacity: 1; color: var(--latte); }

        /* Footer */
        .sidebar-footer {
            border-top: 1px solid rgba(181,117,42,0.1);
            padding: 16px 0;
            flex-shrink: 0;
            position: relative;
            z-index: 1;
        }
        .sidebar-footer .nav-link { font-size: 12px; }
        .sidebar-footer form { margin: 0; }
        .sidebar-footer button {
            background: none; border: none; cursor: pointer;
            display: flex; align-items: center; gap: 12px;
            padding: 11px 24px;
            color: rgba(245,237,224,0.4);
            font-size: 12px;
            font-family: 'DM Sans', sans-serif;
            width: 100%;
            letter-spacing: 0.3px;
            border-left: 2px solid transparent;
            transition: all 0.2s;
        }
        .sidebar-footer button i { width: 18px; font-size: 14px; text-align: center; }
        .sidebar-footer button:hover { color: #e74c3c; background: rgba(231,76,60,0.06); border-left-color: rgba(231,76,60,0.3); }

        /* ── MAIN CONTENT ──────────────────────────────────── */
        .admin-content {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Top bar */
        .admin-topbar {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0 36px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .topbar-title {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--espresso);
        }
        .topbar-title em { font-style: italic; color: var(--caramel); }
        .topbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
            font-size: 13px;
            color: var(--muted);
        }
        .topbar-date {
            font-size: 12px;
            letter-spacing: 0.5px;
            color: var(--muted);
        }
        .topbar-admin-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--foam);
            border: 1px solid var(--border);
            border-radius: 2px;
            padding: 6px 14px;
            font-size: 11px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--caramel);
        }

        /* Page body */
        .admin-body { padding: 32px 36px 60px; flex: 1; }

        /* ── SHARED COMPONENTS ─────────────────────────────── */

        /* Page header */
        .page-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .page-eyebrow {
            font-size: 10px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--caramel);
            margin-bottom: 6px;
            display: flex; align-items: center; gap: 8px;
        }
        .page-eyebrow::before { content: ''; display: block; width: 20px; height: 1px; background: var(--caramel); }
        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 30px;
            font-weight: 700;
            color: var(--espresso);
            line-height: 1.1;
        }
        .page-title em { font-style: italic; color: var(--caramel); }

        /* Stat cards */
        .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 28px; }
        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 24px 22px;
            display: flex;
            flex-direction: column;
            gap: 0;
            transition: box-shadow 0.25s, transform 0.25s;
        }
        .stat-card:hover { box-shadow: 0 8px 32px rgba(28,15,8,0.08); transform: translateY(-3px); }
        .stat-card-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 16px; }
        .stat-icon {
            width: 42px; height: 42px;
            border: 1px solid var(--border);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: var(--caramel);
            font-size: 16px;
        }
        .stat-trend { font-size: 11px; color: #2e7d32; background: rgba(46,125,50,0.08); border: 1px solid rgba(46,125,50,0.15); padding: 3px 8px; border-radius: 2px; }
        .stat-num {
            font-family: 'Playfair Display', serif;
            font-size: 34px;
            font-weight: 700;
            color: var(--espresso);
            line-height: 1;
            margin-bottom: 5px;
        }
        .stat-label { font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); margin-bottom: 12px; }
        .stat-link { font-size: 12px; color: var(--caramel); text-decoration: none; display: inline-flex; align-items: center; gap: 5px; transition: gap 0.2s; border-bottom: 1px solid rgba(181,117,42,0.25); }
        .stat-link:hover { gap: 10px; color: var(--espresso); }

        /* Panel card */
        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 24px;
        }
        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 24px;
            border-bottom: 1px solid var(--border);
        }
        .panel-title-group { display: flex; align-items: center; gap: 12px; }
        .panel-icon {
            width: 32px; height: 32px;
            border: 1px solid rgba(181,117,42,0.2);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: var(--caramel); font-size: 13px;
        }
        .panel-title { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 700; color: var(--espresso); }
        .panel-body { padding: 24px; }
        .panel-body-flush { padding: 0; }

        /* Table */
        .admin-table { width: 100%; border-collapse: collapse; }
        .admin-table thead th {
            background: var(--foam);
            padding: 12px 16px;
            font-size: 10px;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--muted);
            border-bottom: 1px solid var(--border);
            text-align: left;
            white-space: nowrap;
        }
        .admin-table tbody td {
            padding: 14px 16px;
            border-bottom: 1px solid rgba(181,117,42,0.06);
            color: var(--text);
            font-size: 13px;
            vertical-align: middle;
        }
        .admin-table tbody tr:last-child td { border-bottom: none; }
        .admin-table tbody tr:hover td { background: var(--foam); }

        /* Status badges */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 2px;
            font-size: 10px;
            font-weight: 500;
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }
        .status-badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; opacity: 0.7; }
        .status-badge.completed  { background: rgba(46,125,50,0.08);  color: #2e7d32; border: 1px solid rgba(46,125,50,0.2); }
        .status-badge.pending    { background: rgba(181,117,42,0.08); color: var(--caramel); border: 1px solid rgba(181,117,42,0.22); }
        .status-badge.processing { background: rgba(41,98,255,0.07);  color: #2962ff; border: 1px solid rgba(41,98,255,0.15); }
        .status-badge.shipped    { background: rgba(0,137,123,0.07);  color: #00897b; border: 1px solid rgba(0,137,123,0.15); }
        .status-badge.delivered  { background: rgba(46,125,50,0.08);  color: #2e7d32; border: 1px solid rgba(46,125,50,0.2); }
        .status-badge.cancelled  { background: rgba(192,57,43,0.07);  color: #c0392b; border: 1px solid rgba(192,57,43,0.15); }
        .status-badge.failed     { background: rgba(192,57,43,0.07);  color: #c0392b; border: 1px solid rgba(192,57,43,0.15); }
        .status-badge.approved   { background: rgba(46,125,50,0.08);  color: #2e7d32; border: 1px solid rgba(46,125,50,0.2); }
        .status-badge.review-pending { background: rgba(181,117,42,0.08); color: var(--caramel); border: 1px solid rgba(181,117,42,0.22); }
        .status-badge.available  { background: rgba(46,125,50,0.08);  color: #2e7d32; border: 1px solid rgba(46,125,50,0.2); }
        .status-badge.unavailable{ background: rgba(122,106,90,0.08); color: var(--muted); border: 1px solid rgba(122,106,90,0.15); }
        .status-badge.in-stock   { background: rgba(46,125,50,0.08);  color: #2e7d32; border: 1px solid rgba(46,125,50,0.2); }
        .status-badge.low-stock  { background: rgba(181,117,42,0.08); color: var(--caramel); border: 1px solid rgba(181,117,42,0.22); }
        .status-badge.out-of-stock { background: rgba(192,57,43,0.07); color: #c0392b; border: 1px solid rgba(192,57,43,0.15); }
        .status-badge.trending   { background: rgba(181,117,42,0.12); color: var(--caramel); border: 1px solid rgba(181,117,42,0.3); }

        /* Action buttons */
        .action-btn {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 6px 12px; border-radius: 2px;
            font-size: 11px; font-weight: 500; letter-spacing: 1px; text-transform: uppercase;
            text-decoration: none; border: none; cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            transition: all 0.2s;
        }
        .action-btn-primary { background: var(--espresso); color: var(--cream); }
        .action-btn-primary:hover { background: var(--caramel); color: white; }
        .action-btn-ghost { background: transparent; border: 1px solid rgba(181,117,42,0.25); color: var(--caramel); }
        .action-btn-ghost:hover { background: var(--caramel); color: white; border-color: var(--caramel); }
        .action-btn-danger { background: transparent; border: 1px solid rgba(192,57,43,0.25); color: #c0392b; }
        .action-btn-danger:hover { background: #c0392b; color: white; border-color: #c0392b; }
        .action-btn-warn { background: transparent; border: 1px solid rgba(181,117,42,0.3); color: var(--caramel); }
        .action-btn-warn:hover { background: var(--caramel); color: white; }
        .action-btn-success { background: transparent; border: 1px solid rgba(46,125,50,0.25); color: #2e7d32; }
        .action-btn-success:hover { background: #2e7d32; color: white; }

        /* CTA button */
        .btn-cta {
            display: inline-flex; align-items: center; gap: 8px;
            background: var(--espresso); color: var(--cream); border: none;
            padding: 12px 24px; border-radius: 2px;
            font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500;
            letter-spacing: 2px; text-transform: uppercase; text-decoration: none; cursor: pointer;
            transition: background 0.25s, transform 0.2s;
        }
        .btn-cta:hover { background: var(--caramel); color: white; transform: translateY(-1px); }
        .btn-cta-outline {
            background: transparent; border: 1.5px solid rgba(181,117,42,0.3);
            color: var(--caramel);
        }
        .btn-cta-outline:hover { background: var(--espresso); border-color: var(--espresso); color: var(--cream); }

        /* Alert */
        .admin-alert {
            display: flex; align-items: flex-start; gap: 12px;
            padding: 14px 18px; border-radius: 2px; margin-bottom: 20px; font-size: 13px;
        }
        .admin-alert.success { background: rgba(46,125,50,0.07); border: 1px solid rgba(46,125,50,0.2); color: #2e7d32; }
        .admin-alert.info    { background: rgba(181,117,42,0.07); border: 1px solid rgba(181,117,42,0.2); color: var(--caramel); }

        /* Empty state */
        .empty-state { padding: 60px 32px; text-align: center; }
        .empty-state i { font-size: 44px; color: rgba(181,117,42,0.2); display: block; margin-bottom: 16px; }
        .empty-state p { font-size: 15px; color: var(--muted); font-style: italic; }

        /* Progress bar */
        .admin-progress { height: 6px; background: rgba(181,117,42,0.1); border-radius: 2px; overflow: hidden; }
        .admin-progress-fill { height: 100%; background: var(--caramel); border-radius: 2px; transition: width 0.4s ease; }

        /* Grid helpers */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }

        /* ── RESPONSIVE ─────────────────────────────────────── */
        @@media (max-width: 1100px) { .stats-row { grid-template-columns: repeat(2, 1fr); } }
        @@media (max-width: 900px)  { .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; } }
        @@media (max-width: 768px) {
            .admin-sidebar { transform: translateX(-100%); }
            .admin-content { margin-left: 0; }
            .admin-body { padding: 20px 16px 40px; }
            .admin-topbar { padding: 0 20px; }
            .stats-row { grid-template-columns: 1fr 1fr; }
        }
        .sidebar-toggle {
            display: none;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 3px;
            color: var(--espresso);
            font-size: 15px;
            cursor: pointer;
            flex-shrink: 0;
            transition: background 0.2s, color 0.2s;
        }

            .sidebar-toggle:hover {
                background: var(--foam);
                color: var(--caramel);
            }

        /* ── OVERLAY ──────────────────────────────────────── */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(28, 15, 8, 0.55);
            z-index: 999;
            backdrop-filter: blur(2px);
            opacity: 0;
            transition: opacity 0.3s;
        }

            .sidebar-overlay.active {
                display: block;
                opacity: 1;
            }

        /* ── RESPONSIVE ───────────────────────────────────── */
        @@media (max-width: 1100px) {
            .stats-row {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 900px) {
            .grid-2, .grid-3, .grid-4 {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            /* Show hamburger */
            .sidebar-toggle {
                display: flex;
            }
            /* Slide sidebar off-screen by default */
            .admin-sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                z-index: 1000;
            }

                .admin-sidebar.open {
                    transform: translateX(0);
                    box-shadow: 8px 0 40px rgba(28,15,8,0.35);
                }

            .admin-content {
                margin-left: 0;
            }

            .admin-body {
                padding: 20px 16px 40px;
            }

            .admin-topbar {
                padding: 0 16px;
                gap: 12px;
            }
            /* Hide date on very small screens, keep badge */
            .topbar-date {
                display: none;
            }

            .stats-row {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media (max-width: 480px) {
            .stats-row {
                grid-template-columns: 1fr;
            }

            .topbar-admin-badge {
                display: none;
            }

            .admin-topbar {
                padding: 0 12px;
            }

            .page-title {
                font-size: 22px;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
<!-- ═══ SIDEBAR ═══ -->
<aside class="admin-sidebar">
    <div class="sidebar-brand">
        <a href="/" class="sidebar-brand-logo">
            <div class="brand-icon"><i class="fas fa-coffee"></i></div>
            <span class="brand-name">Coffee Shop</span>
        </a>
        <div class="brand-role">Admin Panel</div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section-label">Overview</div>
        <a href="/Admin/Dashboard" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
            <i class="fas fa-th-large"></i> Dashboard
        </a>

        <div class="nav-section-label">Manage</div>
        <a href="/Admin/Products" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Products" ? "active" : "")">
            <i class="fas fa-box"></i> Products
        </a>
        <a href="/Admin/Orders" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() is "Orders" or "OrderDetails" ? "active" : "")">
            <i class="fas fa-receipt"></i> Orders
        </a>
        <a href="/Admin/Reviews" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Reviews" ? "active" : "")">
            <i class="fas fa-star"></i> Reviews
        </a>

        <div class="nav-section-label">Finance</div>
        <a href="/Admin/Payments" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Payments" ? "active" : "")">
            <i class="fas fa-credit-card"></i> Payments
        </a>
        <a href="/Admin/SalesReport" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SalesReport" ? "active" : "")">
            <i class="fas fa-chart-line"></i> Sales Report
        </a>
    </nav>

    <div class="sidebar-footer">
        <a href="/" class="nav-link" style="font-size:12px;">
            <i class="fas fa-arrow-left"></i> Back to Store
        </a>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
            <button type="submit"><i class="fas fa-sign-out-alt"></i> Sign Out</button>
        </form>
    </div>
</aside>

<!-- ═══ MAIN ═══ -->
<div class="admin-content">
        <header class="admin-topbar">
            <button class="sidebar-toggle" id="sidebarToggle" onclick="toggleSidebar()" aria-label="Toggle menu">
                <i class="fas fa-bars"></i>
            </button>
            <div class="topbar-title">@(ViewData["Title"]?.ToString()?.Replace("Manage ", ""))</div>
            <div class="topbar-right">
                <span class="topbar-date">@DateTime.Now.ToString("MMMM dd, yyyy")</span>
                <div class="topbar-admin-badge"><i class="fas fa-shield-alt"></i> Admin</div>
            </div>
        </header>

    <div class="admin-body">
        @RenderBody()
    </div>
</div>

<script src="~/bootstrap/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", false)
<script>
    function toggleSidebar() {
        const sidebar = document.querySelector('.admin-sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const isOpen = sidebar.classList.toggle('open');
        overlay.classList.toggle('active', isOpen);
        document.body.style.overflow = isOpen ? 'hidden' : '';
    }

    // Close sidebar when a nav link is clicked (mobile UX)
    document.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', () => {
            if (window.innerWidth <= 768) {
                document.querySelector('.admin-sidebar').classList.remove('open');
                document.getElementById('sidebarOverlay').classList.remove('active');
                document.body.style.overflow = '';
            }
        });
    });

    // Close on resize back to desktop
    window.addEventListener('resize', () => {
        if (window.innerWidth > 768) {
            document.querySelector('.admin-sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('active');
            document.body.style.overflow = '';
        }
    });
</script>
</body>
</html>
