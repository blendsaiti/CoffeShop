@model IEnumerable<ShoppingCartitem>
@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --espresso: #1c0f08;
        --caramel: #b5752a;
        --latte: #d4a96a;
        --cream: #f5ede0;
        --foam: #faf6f0;
        --border: rgba(181,117,42,0.12);
        --muted: #7a6a5a;
    }

    .cart-section {
        min-height: 80vh;
        padding: 60px 0;
        background: var(--foam);
    }

    .cart-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 28px;
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 28px;
    }

    @@media(max-width:900px) {
        .cart-wrap {
            grid-template-columns: 1fr;
        }
    }

    .cart-panel {
        background: white;
        border: 1px solid var(--border);
        border-radius: 3px;
        overflow: hidden;
    }

    .cart-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
    }

    .cart-panel-title {
        font-family: 'Playfair Display',serif;
        font-size: 22px;
        font-weight: 700;
        color: var(--espresso);
    }

    .cart-count-pill {
        font-size: 11px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--muted);
        background: var(--foam);
        border: 1px solid var(--border);
        padding: 4px 10px;
        border-radius: 2px;
    }

    .cart-item {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 18px 24px;
        border-bottom: 1px solid rgba(181,117,42,0.06);
        transition: background 0.15s;
    }

        .cart-item:last-child {
            border-bottom: none;
        }

        .cart-item:hover {
            background: var(--foam);
        }

    .cart-item-img {
        width: 72px;
        height: 72px;
        flex-shrink: 0;
        object-fit: contain;
        background: var(--foam);
        border: 1px solid var(--border);
        border-radius: 2px;
        padding: 6px;
    }

    .cart-item-name {
        font-family: 'Playfair Display',serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--espresso);
        margin-bottom: 4px;
    }

    .cart-item-qty {
        font-size: 12px;
        color: var(--muted);
    }

    .cart-item-price {
        font-family: 'Playfair Display',serif;
        font-size: 17px;
        font-weight: 700;
        color: var(--caramel);
        margin-left: auto;
        white-space: nowrap;
    }

    .cart-remove {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: transparent;
        border: 1px solid rgba(192,57,43,0.2);
        color: #c0392b;
        text-decoration: none;
        font-size: 12px;
        transition: all 0.2s;
        flex-shrink: 0;
    }

        .cart-remove:hover {
            background: #c0392b;
            color: white;
            border-color: #c0392b;
        }

    .summary-panel {
        background: white;
        border: 1px solid var(--border);
        border-radius: 3px;
        overflow: hidden;
        position: sticky;
        top: 90px;
        height: fit-content;
    }

    .summary-header {
        padding: 18px 22px;
        border-bottom: 1px solid var(--border);
    }

    .summary-title {
        font-family: 'Playfair Display',serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--espresso);
    }

    .summary-body {
        padding: 22px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        padding: 10px 0;
        border-bottom: 1px solid rgba(181,117,42,0.06);
    }

        .summary-row.total {
            border-top: 1.5px solid var(--border);
            border-bottom: none;
            padding-top: 16px;
            margin-top: 4px;
        }

            .summary-row.total .lbl {
                font-size: 11px;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--muted);
            }

            .summary-row.total .val {
                font-family: 'Playfair Display',serif;
                font-size: 26px;
                font-weight: 700;
                color: var(--caramel);
            }

    .checkout-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        width: 100%;
        background: var(--espresso);
        color: var(--cream);
        padding: 16px;
        border-radius: 2px;
        text-decoration: none;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans',sans-serif;
        transition: background 0.2s;
    }

        .checkout-btn:hover {
            background: var(--caramel);
            color: white;
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-size: 12px;
        color: var(--muted);
        text-decoration: none;
        margin-top: 16px;
        transition: color 0.2s;
    }

        .back-link:hover {
            color: var(--caramel);
        }

    .empty-cart {
        padding: 80px 40px;
        text-align: center;
    }

        .empty-cart i {
            font-size: 24px;
            color: rgba(181,117,42,0.18);
            display: block;
        }

        .empty-cart h2 {
            font-family: 'Playfair Display',serif;
            font-size: 26px;
            font-weight: 700;
            color: var(--espresso);
            margin-bottom: 10px;
        }

        .empty-cart p {
            font-size: 15px;
            color: var(--muted);
            margin-bottom: 28px;
            max-width: 400px;
            margin-left: auto;
            margin-right: auto;
        }

    .shop-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--espresso);
        color: var(--cream);
        padding: 14px 28px;
        border-radius: 2px;
        text-decoration: none;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
        transition: background 0.2s;
    }

        .shop-btn:hover {
            background: var(--caramel);
            color: white;
        }
</style>

@if (Model?.Any() == true)
{
    <div class="cart-section">
        <div class="cart-wrap">
            <div class="cart-panel">
                <div class="cart-panel-header">
                    <span class="cart-panel-title">Shopping Cart</span>
                    <span class="cart-count-pill">@Model.Count() items</span>
                </div>
                <div>
                    @foreach (var item in Model)
                    {
                        <div class="cart-item">
                            <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="cart-item-img">
                            <div style="flex:1;min-width:0;">
                                <div class="cart-item-name">@item.Product.Name</div>
                                <div class="cart-item-qty">Quantity: @item.Qty</div>
                            </div>
                            <div class="cart-item-price">$@((item.Qty * item.Product.Price).ToString("0.00"))</div>
                            <a asp-controller="ShoppingCart" asp-action="RemoveFromShoppingCart" asp-route-pId="@item.Product.ProductID" class="cart-remove" title="Remove">
                                <i class="fas fa-times"></i>
                            </a>
                        </div>
                    }
                </div>
                <div style="padding:18px 24px;">
                    <a asp-controller="Products" asp-action="Shop" class="back-link">
                        <i class="fas fa-arrow-left"></i> Continue Shopping
                    </a>
                </div>
            </div>

            <div class="summary-panel">
                <div class="summary-header"><div class="summary-title">Order Summary</div></div>
                <div class="summary-body">
                    @foreach (var item in Model)
                    {
                        <div class="summary-row">
                            <span style="color:var(--muted);">@item.Product.Name <span style="opacity:0.6;">×@item.Qty</span></span>
                            <strong>$@((item.Qty * item.Product.Price).ToString("0.00"))</strong>
                        </div>
                    }
                    <div class="summary-row" style="border-bottom:none;">
                        <span style="color:var(--muted);">Shipping</span>
                        <span style="color:#2e7d32;font-weight:500;font-size:12px;"><i class="fas fa-check" style="font-size:10px;margin-right:3px;"></i>FREE</span>
                    </div>
                    <div class="summary-row total">
                        <span class="lbl">Total</span>
                        <span class="val">@ViewBag.CartTotal.ToString("c")</span>
                    </div>
                    <div style="margin:20px 0 14px;">
                        <a asp-controller="Orders" asp-action="Checkout" class="checkout-btn">
                            <i class="fas fa-lock" style="font-size:10px;"></i> Proceed to Checkout
                        </a>
                    </div>
                    <div style="text-align:center;font-size:11px;color:var(--muted);">
                        <i class="fas fa-shield-alt" style="color:var(--caramel);margin-right:4px;"></i> Secure 256-bit SSL checkout
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="cart-section">
        <div style="max-width:560px;margin:0 auto;padding:0 28px;">
            <div class="cart-panel">
                <div class="empty-cart">
                    <i class="fas fa-shopping-bag"></i>
                    <h2>Your cart is empty</h2>
                    <p>Explore our collection and add some wonderful coffee products to get started.</p>
                    <a asp-controller="Products" asp-action="Shop" class="shop-btn">
                        <i class="fas fa-coffee"></i> Browse the Shop
                    </a>
                </div>
            </div>
        </div>
    </div>
}
