        }

        .brands-row {
            gap: 20px;
        }

        .brand-item img {
            max-height: 32px;
            max-width: 80px;
        }
    }

    /* ── SCROLL REVEAL ── */
    [data-reveal] {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity .65s ease, transform .65s ease;
    }

        [data-reveal].visible {
            opacity: 1;
            transform: none;
        }
</style>

