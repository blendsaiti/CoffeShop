@using CoffeeShop.ViewModels
@model ProductListViewModel

<div class="results-bar">
    <div class="results-text">
        Showing <strong>@(Model.TotalProducts == 0 ? 0 : Model.StartProduct) - @Model.EndProduct</strong>
        of <strong>@Model.TotalProducts</strong> products
    </div>
</div>

<div class="products-grid">
    @if (Model.Products != null && Model.Products.Any())
    {
        foreach (var product in Model.Products)
        {
            <div class="product-card">
                <div class="product-img-wrap">
                    <img src="@product.ImageUrl" alt="@product.Name" />
                    <div class="product-overlay">
                        <a asp-action="Detail" asp-route-id="@product.ProductID" class="overlay-btn" title="View Details">
                            <i class="fas fa-eye"></i>
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@product.ProductID" class="overlay-btn warning" title="Edit">
                                <i class="fas fa-edit"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@product.ProductID" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="overlay-btn danger"
                                        title="Delete"
                                        onclick="return confirm('Are you sure you want to delete this product?')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>

                <div class="product-info">
                    <div class="product-cat">@(product.Category?.Name ?? "Coffee")</div>

                    <h3 class="product-name">
                        <a asp-action="Detail" asp-route-id="@product.ProductID">@product.Name</a>
                    </h3>

                    <div class="product-footer">
                        <div class="product-price">$@product.Price.ToString("F2")</div>
                        <button type="button" class="cart-btn" onclick="addToCart(@product.ProductID, this)">
                            <i class="fas fa-shopping-cart"></i> Add
                        </button>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-coffee"></i>
            <p>No products found matching your criteria</p>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="pagination-wrapper">
        <ul class="pagination">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a href="#" class="page-link ajax-page-link" data-page="@(Model.CurrentPage - 1)">
                    <i class="fas fa-chevron-left"></i>
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a href="#" class="page-link ajax-page-link" data-page="@i">@i</a>
                </li>
            }

            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a href="#" class="page-link ajax-page-link" data-page="@(Model.CurrentPage + 1)">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        </ul>
    </div>
}