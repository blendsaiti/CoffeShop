@model CoffeeShop.Models.Product
@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Products</div>
        <h1 class="page-title">Edit <em>@Model.Name</em></h1>
    </div>
    <a asp-action="Products" asp-controller="Admin" class="btn-cta btn-cta-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div style="max-width:680px;">
    <div class="panel">
        <div class="panel-header">
            <div class="panel-title-group">
                <div class="panel-icon"><i class="fas fa-edit"></i></div>
                <span class="panel-title">Product Details</span>
            </div>
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" style="width:48px;height:48px;object-fit:contain;background:var(--foam);border:1px solid var(--border);border-radius:2px;padding:3px;">
            }
        </div>
        <div class="panel-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="ProductID" />
                <div style="margin-bottom:18px;">
                    <label style="display:block;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;">Product Name *</label>
                    <input asp-for="Name" style="width:100%;background:var(--foam);border:1px solid rgba(181,117,42,0.18);border-radius:2px;padding:11px 13px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);outline:none;" />
                    <span asp-validation-for="Name" style="font-size:11px;color:#c0392b;margin-top:4px;display:block;"></span>
                </div>
                <div style="margin-bottom:18px;">
                    <label style="display:block;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;">Description</label>
                    <textarea asp-for="Detail" rows="4" style="width:100%;background:var(--foam);border:1px solid rgba(181,117,42,0.18);border-radius:2px;padding:11px 13px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);outline:none;resize:vertical;"></textarea>
                    <span asp-validation-for="Detail" style="font-size:11px;color:#c0392b;"></span>
                </div>
                <div style="margin-bottom:18px;">
                    <label style="display:block;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;">Image URL</label>
                    <input asp-for="ImageUrl" style="width:100%;background:var(--foam);border:1px solid rgba(181,117,42,0.18);border-radius:2px;padding:11px 13px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);outline:none;" />
                    <span asp-validation-for="ImageUrl" style="font-size:11px;color:#c0392b;"></span>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px;">
                    <div>
                        <label style="display:block;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;">Price *</label>
                        <input asp-for="Price" type="number" step="0.01" style="width:100%;background:var(--foam);border:1px solid rgba(181,117,42,0.18);border-radius:2px;padding:11px 13px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);outline:none;" />
                        <span asp-validation-for="Price" style="font-size:11px;color:#c0392b;"></span>
                    </div>
                    <div>
                        <label style="display:block;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;">Stock Quantity</label>
                        <input asp-for="StockQuantity" type="number" style="width:100%;background:var(--foam);border:1px solid rgba(181,117,42,0.18);border-radius:2px;padding:11px 13px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);outline:none;" />
                    </div>
                </div>
                <div style="margin-bottom:24px;display:flex;align-items:center;gap:10px;background:var(--foam);border:1px solid var(--border);border-radius:2px;padding:14px;">
                    <input asp-for="IsTrendingProduct" type="checkbox" id="trending" style="width:16px;height:16px;accent-color:var(--caramel);cursor:pointer;">
                    <label for="trending" style="font-size:13px;font-weight:500;color:var(--text);cursor:pointer;margin:0;">Mark as Trending / Best Seller</label>
                </div>
                <div style="display:flex;gap:10px;">
                    <button type="submit" class="btn-cta"><i class="fas fa-save"></i> Save Changes</button>
                    <a asp-action="Products" asp-controller="Admin" class="btn-cta btn-cta-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
