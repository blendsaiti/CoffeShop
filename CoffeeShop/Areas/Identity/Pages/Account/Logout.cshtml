@page
@model LogoutModel

@{
    // Auto-logout when page loads
    if (User.Identity?.IsAuthenticated ?? false)
    {
        // User is still logged in - auto-submit logout form
    }
    else
    {
        // User is logged out - show success message
    }
}

<!DOCTYPE html>
<html>
<head>
    <title>Logging out...</title>
    <style>
        body {
            font-family: 'Jost', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        }

        .logout-container {
            text-align: center;
            background: white;
            padding: 60px 80px;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #d7a86e;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
            margin: 0 auto 30px;
        }

        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        h2 {
            color: #2d3748;
            margin-bottom: 15px;
            font-size: 28px;
        }

        p {
            color: #718096;
            font-size: 16px;
        }

        .success-icon {
            font-size: 64px;
            color: #48bb78;
            margin-bottom: 20px;
        }

        .btn-home {
            display: inline-block;
            margin-top: 30px;
            padding: 12px 30px;
            background: #d7a86e;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-home:hover {
                background: #b8884a;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(215, 168, 110, 0.3);
            }
    </style>
</head>
<body>
    <div class="logout-container">
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <!-- User is still logged in - show loading and auto-submit -->
            <div class="spinner"></div>
            <h2>Logging out...</h2>
            <p>Please wait while we log you out</p>

            <!-- Hidden auto-submit form -->
            <form id="logoutForm" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" style="display:none;">
                <button type="submit">Logout</button>
            </form>

            <script>
                // Auto-submit form when page loads
                document.getElementById('logoutForm').submit();
            </script>
        }
        else
        {
            <!-- User is logged out - show success message -->
            <div class="success-icon">✓</div>
            <h2>Successfully Logged Out</h2>
            <p>You have been logged out of your account.</p>
            <a href="/" class="btn-home">
                <i class="fas fa-home me-2"></i> Return to Home
            </a>
        }
    </div>
</body>
</html>
