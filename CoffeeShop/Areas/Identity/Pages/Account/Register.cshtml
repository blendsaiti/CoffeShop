@page
@model RegisterModel

@{
    ViewData["Title"] = "Create Account";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=DM+Sans:wght@300;400;500&family=Cormorant+Garamond:ital,wght@0,300;1,300&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --espresso: #1c0f08;
        --roast: #3b1f0e;
        --caramel: #b5752a;
        --latte: #d4a96a;
        --cream: #f5ede0;
        --foam: #faf6f0;
        --warm-grey: #7a6a5a;
    }

    .auth-page {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        font-family: 'DM Sans', sans-serif;
    }

    /* ── LEFT PANEL ─────────────────────────────────────────────────── */
    .auth-visual {
        background: var(--roast);
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 56px;
        overflow: hidden;
        order: 2;
    }

    .auth-visual-bg {
        position: absolute;
        inset: 0;
        background-image: url('https://images.unsplash.com/photo-1442512595331-e89e73853f31?auto=format&fit=crop&w=1200&q=80');
        background-size: cover;
        background-position: center;
        opacity: 0.15;
    }

    .auth-visual::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(160deg, rgba(181,117,42,0.14) 0%, transparent 60%);
        pointer-events: none;
    }

    .auth-logo {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
    }

    .auth-logo-icon {
        width: 42px;
        height: 42px;
        border: 1px solid rgba(181,117,42,0.4);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--latte);
        font-size: 18px;
    }

    .auth-logo-text {
        font-family: 'Playfair Display', serif;
        font-size: 20px;
        font-weight: 700;
        color: var(--cream);
    }

    .auth-visual-copy {
        position: relative;
        z-index: 2;
    }

    .auth-visual-eyebrow {
        font-size: 10px;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: var(--latte);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .auth-visual-eyebrow::before {
            content: '';
            display: block;
            width: 28px;
            height: 1px;
            background: var(--latte);
        }

    .auth-visual-copy h2 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(34px, 3.2vw, 50px);
        font-weight: 900;
        color: var(--cream);
        line-height: 1.05;
        margin-bottom: 18px;
    }

        .auth-visual-copy h2 em {
            font-style: italic;
            color: var(--latte);
        }

    .auth-visual-copy p {
        font-family: 'Cormorant Garamond', serif;
        font-size: 18px;
        font-weight: 300;
        font-style: italic;
        color: rgba(245,237,224,0.55);
        line-height: 1.7;
        max-width: 300px;
    }

    /* Perks list */
    .auth-perks {
        position: relative;
        z-index: 2;
        list-style: none;
        padding: 0;
        margin: 28px 0 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

        .auth-perks li {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 13px;
            color: rgba(245,237,224,0.6);
        }

    .perk-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--caramel);
        flex-shrink: 0;
    }

    .auth-visual-deco {
        position: absolute;
        top: -80px;
        left: -80px;
        width: 320px;
        height: 320px;
        border-radius: 50%;
        border: 1px solid rgba(181,117,42,0.08);
        z-index: 1;
    }

    .auth-visual-deco-2 {
        top: -140px;
        left: -140px;
        width: 500px;
        height: 500px;
        border-color: rgba(181,117,42,0.05);
    }

    /* ── RIGHT PANEL ────────────────────────────────────────────────── */
    .auth-form-panel {
        background: var(--foam);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 56px 48px;
        order: 1;
    }

    .auth-form-wrap {
        width: 100%;
        max-width: 400px;
    }

    .auth-form-header {
        margin-bottom: 36px;
    }

    .auth-form-eyebrow {
        font-size: 10px;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: var(--caramel);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .auth-form-eyebrow::before {
            content: '';
            display: block;
            width: 24px;
            height: 1px;
            background: var(--caramel);
        }

    .auth-form-title {
        font-family: 'Playfair Display', serif;
        font-size: 38px;
        font-weight: 900;
        color: var(--espresso);
        line-height: 1.05;
        margin-bottom: 8px;
    }

        .auth-form-title em {
            font-style: italic;
            color: var(--caramel);
        }

    .auth-form-subtitle {
        font-size: 14px;
        color: var(--warm-grey);
    }

        .auth-form-subtitle a {
            color: var(--caramel);
            text-decoration: none;
            font-weight: 500;
            border-bottom: 1px solid rgba(181,117,42,0.3);
            transition: border-color 0.2s;
        }

            .auth-form-subtitle a:hover {
                border-color: var(--caramel);
            }

    /* Alert */
    .auth-alert {
        background: rgba(192,57,43,0.07);
        border: 1px solid rgba(192,57,43,0.2);
        border-radius: 2px;
        padding: 13px 16px;
        font-size: 13px;
        color: #c0392b;
        margin-bottom: 20px;
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }

        .auth-alert i {
            margin-top: 1px;
            flex-shrink: 0;
        }

    /* Fields */
    .auth-field {
        margin-bottom: 18px;
    }

    .auth-label {
        display: block;
        font-size: 10px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--warm-grey);
        margin-bottom: 8px;
        font-weight: 500;
    }

    .auth-input-wrap {
        position: relative;
    }

    .auth-input-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(181,117,42,0.45);
        font-size: 14px;
        pointer-events: none;
    }

    .auth-input {
        width: 100%;
        background: white;
        border: 1px solid rgba(181,117,42,0.2);
        border-radius: 2px;
        padding: 14px 16px 14px 44px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        color: var(--espresso);
        outline: none;
        transition: border-color 0.25s, box-shadow 0.25s;
    }

        .auth-input:focus {
            border-color: var(--caramel);
            box-shadow: 0 0 0 3px rgba(181,117,42,0.08);
        }

        .auth-input::placeholder {
            color: rgba(122,106,90,0.4);
        }

    .field-error {
        font-size: 12px;
        color: #c0392b;
        margin-top: 6px;
        display: block;
    }

    /* Password strength hint */
    .password-hint {
        font-size: 11px;
        color: rgba(122,106,90,0.55);
        margin-top: 6px;
        letter-spacing: 0.3px;
    }

    /* Submit */
    .auth-submit {
        width: 100%;
        background: var(--espresso);
        color: var(--cream);
        border: none;
        padding: 16px;
        border-radius: 2px;
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 3px;
        text-transform: uppercase;
        cursor: pointer;
        margin-top: 8px;
        transition: background 0.25s, transform 0.2s, box-shadow 0.25s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .auth-submit:hover {
            background: var(--caramel);
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(181,117,42,0.3);
        }

    .auth-terms {
        font-size: 11px;
        color: rgba(122,106,90,0.5);
        text-align: center;
        margin-top: 14px;
        line-height: 1.6;
    }

        .auth-terms a {
            color: var(--caramel);
            text-decoration: none;
            border-bottom: 1px solid rgba(181,117,42,0.3);
        }

    /* External */
    .auth-divider {
        display: flex;
        align-items: center;
        gap: 16px;
        margin: 20px 0;
        font-size: 11px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: rgba(122,106,90,0.4);
    }

        .auth-divider::before, .auth-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(181,117,42,0.15);
        }

    .external-btn {
        width: 100%;
        background: white;
        border: 1px solid rgba(181,117,42,0.2);
        border-radius: 2px;
        padding: 13px 16px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        color: var(--espresso);
        cursor: pointer;
        transition: border-color 0.25s, box-shadow 0.25s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 10px;
    }

        .external-btn:hover {
            border-color: var(--caramel);
            box-shadow: 0 4px 14px rgba(181,117,42,0.1);
        }

    @@media (max-width: 768px) {
        .auth-page {
            grid-template-columns: 1fr;
        }

        .auth-visual {
            display: none;
        }

        .auth-form-panel {
            padding: 48px 24px;
            order: 1;
        }
    }
</style>

<div class="auth-page">

    <!-- Form Panel -->
    <div class="auth-form-panel">
        <div class="auth-form-wrap">

            <div class="auth-form-header">
                <div class="auth-form-eyebrow">New Member</div>
                <h1 class="auth-form-title">Create <em>Account</em></h1>
                <p class="auth-form-subtitle">
                    Already have one? <a asp-page="./Login">Sign in here</a>
                </p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="auth-alert">
                    <i class="fas fa-exclamation-circle"></i><span></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Email" class="auth-label">Email Address</label>
                    <div class="auth-input-wrap">
                        <i class="fas fa-envelope auth-input-icon"></i>
                        <input asp-for="Input.Email" class="auth-input" placeholder="you@example.com" autocomplete="username">
                    </div>
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Password" class="auth-label">Password</label>
                    <div class="auth-input-wrap">
                        <i class="fas fa-lock auth-input-icon"></i>
                        <input asp-for="Input.Password" class="auth-input" placeholder="Min. 6 characters" autocomplete="new-password">
                    </div>
                    <span class="password-hint">At least 6 characters with a mix of letters and numbers.</span>
                    <span asp-validation-for="Input.Password" class="field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.ConfirmPassword" class="auth-label">Confirm Password</label>
                    <div class="auth-input-wrap">
                        <i class="fas fa-lock auth-input-icon"></i>
                        <input asp-for="Input.ConfirmPassword" class="auth-input" placeholder="Repeat password" autocomplete="new-password">
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
                </div>

                <button type="submit" class="auth-submit">
                    <i class="fas fa-user-plus"></i> Create Account
                </button>

                <p class="auth-terms">
                    By creating an account you agree to our <a href="/Terms">Terms</a> and <a href="/Privacy">Privacy Policy</a>.
                </p>

                @if (Model.ExternalLogins?.Count > 0)
                {
                    <div class="auth-divider">or sign up with</div>
                    @foreach (var provider in Model.ExternalLogins)
                    {
                        <button type="submit" class="external-btn" name="provider" value="@provider.Name" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl">
                            <i class="fab fa-@provider.Name.ToLower()"></i> @provider.DisplayName
                        </button>
                    }
                }
            </form>

        </div>
    </div>

    <!-- Visual Panel -->
    <div class="auth-visual">
        <div class="auth-visual-bg"></div>
        <div class="auth-visual-deco"></div>
        <div class="auth-visual-deco auth-visual-deco-2"></div>

        <a href="/" class="auth-logo">
            <div class="auth-logo-icon"><i class="fas fa-coffee"></i></div>
            <span class="auth-logo-text">Coffee Shop</span>
        </a>

        <div class="auth-visual-copy">
            <div class="auth-visual-eyebrow">Join the Community</div>
            <h2>Your perfect cup<br><em>awaits</em></h2>
            <p>Become a member and unlock an entire world of premium coffee.</p>
            <ul class="auth-perks">
                <li><span class="perk-dot"></span> Exclusive member-only roasts</li>
                <li><span class="perk-dot"></span> Order tracking & history</li>
                <li><span class="perk-dot"></span> Personal wishlist</li>
                <li><span class="perk-dot"></span> Early access to new arrivals</li>
            </ul>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
