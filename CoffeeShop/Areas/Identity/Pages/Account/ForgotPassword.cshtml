@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --espresso: #1c0f08;
        --caramel: #b5752a;
        --latte: #d4a96a;
        --cream: #f5ede0;
        --foam: #faf6f0;
        --warm-grey: #7a6a5a;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .auth-page {
        min-height: calc(100vh - 68px);
        display: grid;
        grid-template-columns: 1fr 1fr;
        font-family: 'DM Sans', sans-serif;
    }

    /* ── LEFT: dark visual panel ── */
    .auth-visual {
        background: var(--espresso);
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 56px;
        overflow: hidden;
    }

    .auth-visual-bg {
        position: absolute;
        inset: 0;
        background-image: url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&w=1200&q=80');
        background-size: cover;
        background-position: center;
        opacity: 0.15;
    }

    .auth-visual::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(160deg, rgba(181,117,42,0.10) 0%, transparent 60%);
        pointer-events: none;
    }
    /* orbital ring */
    .auth-visual-ring {
        position: absolute;
        border-radius: 50%;
        border: 1px solid rgba(181,117,42,0.08);
        pointer-events: none;
    }

    .auth-logo {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
    }

    .auth-logo-icon {
        width: 42px;
        height: 42px;
        border: 1px solid rgba(181,117,42,0.4);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--latte);
        font-size: 18px;
    }

    .auth-logo-text {
        font-family: 'Playfair Display', serif;
        font-size: 20px;
        font-weight: 700;
        color: var(--cream);
    }

    .auth-visual-body {
        position: relative;
        z-index: 2;
    }

    .auth-tagline {
        font-size: 10px;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: rgba(181,117,42,0.6);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .auth-tagline::before {
            content: '';
            display: block;
            width: 24px;
            height: 1px;
            background: rgba(181,117,42,0.4);
        }

    .auth-headline {
        font-family: 'Playfair Display', serif;
        font-size: clamp(28px, 3.5vw, 42px);
        font-weight: 700;
        line-height: 1.1;
        color: var(--cream);
        margin-bottom: 16px;
    }

        .auth-headline em {
            font-style: italic;
            color: var(--latte);
        }

    .auth-subtext {
        font-family: 'Cormorant Garamond', serif;
        font-size: 17px;
        font-style: italic;
        color: rgba(212,169,106,0.55);
        line-height: 1.6;
    }

    /* ── RIGHT: form panel ── */
    .auth-form-panel {
        background: var(--foam);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 64px 72px;
    }

    .auth-form-eyebrow {
        font-size: 10px;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--caramel);
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .auth-form-eyebrow::before {
            content: '';
            display: block;
            width: 16px;
            height: 1px;
            background: var(--caramel);
        }

    .auth-form-title {
        font-family: 'Playfair Display', serif;
        font-size: 30px;
        font-weight: 700;
        color: var(--espresso);
        margin: 0 0 6px;
        line-height: 1.1;
    }

        .auth-form-title em {
            font-style: italic;
            color: var(--caramel);
        }

    .auth-form-sub {
        font-size: 13px;
        color: var(--warm-grey);
        margin: 0 0 28px;
        line-height: 1.5;
    }

    .af-group {
        margin-bottom: 18px;
    }

    .af-label {
        display: block;
        font-size: 10px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--warm-grey);
        margin-bottom: 7px;
        font-weight: 500;
    }

    .af-input-wrap {
        position: relative;
    }

    .af-input-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(122,106,90,0.4);
        font-size: 13px;
        pointer-events: none;
    }

    .af-input {
        width: 100%;
        background: white;
        border: 1px solid rgba(181,117,42,0.18);
        border-radius: 2px;
        padding: 12px 13px 12px 38px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        color: var(--espresso);
        outline: none;
        transition: border-color 0.2s;
    }

        .af-input:focus {
            border-color: var(--caramel);
            box-shadow: 0 0 0 3px rgba(181,117,42,0.08);
        }

        .af-input::placeholder {
            color: rgba(122,106,90,0.35);
        }

    .af-validation {
        font-size: 11px;
        color: #c0392b;
        margin-top: 4px;
        display: block;
    }

    .af-validation-summary {
        background: rgba(192,57,43,0.06);
        border: 1px solid rgba(192,57,43,0.2);
        border-radius: 2px;
        padding: 10px 14px;
        margin-bottom: 18px;
        font-size: 13px;
        color: #c0392b;
    }

    .af-submit {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        background: var(--espresso);
        color: var(--cream);
        border: none;
        padding: 14px;
        border-radius: 2px;
        font-family: 'DM Sans', sans-serif;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.2s, transform 0.15s;
        margin-top: 4px;
    }

        .af-submit:hover {
            background: var(--caramel);
            transform: translateY(-1px);
        }

    .af-links {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 20px;
        text-align: center;
    }

        .af-links a {
            font-size: 12px;
            color: var(--caramel);
            text-decoration: none;
        }

            .af-links a:hover {
                text-decoration: underline;
            }

        .af-links span {
            font-size: 12px;
            color: var(--warm-grey);
        }

    @@media (max-width: 860px) {
        .auth-page {
            grid-template-columns: 1fr;
        }

        .auth-visual {
            display: none;
        }

        .auth-form-panel {
            padding: 48px 32px;
            min-height: calc(100vh - 68px);
            justify-content: flex-start;
            padding-top: 60px;
        }
    }
</style>

<div class="auth-page">

    <!-- Visual panel -->
    <div class="auth-visual">
        <div class="auth-visual-bg"></div>
        <div class="auth-visual-ring" style="width:500px;height:500px;top:50%;left:50%;transform:translate(-50%,-50%);"></div>
        <div class="auth-visual-ring" style="width:320px;height:320px;top:50%;left:50%;transform:translate(-50%,-50%);"></div>

        <a href="/" class="auth-logo">
            <div class="auth-logo-icon"><i class="fas fa-mug-hot"></i></div>
            <span class="auth-logo-text">Coffee Shop</span>
        </a>

        <div class="auth-visual-body">
            <div class="auth-tagline">Account Recovery</div>
            <h2 class="auth-headline">Forgot your<br><em>Password?</em></h2>
            <p class="auth-subtext">No worries — we'll send you a reset link<br>so you can get back to your coffee.</p>
        </div>

        <div style="position:relative;z-index:2;font-size:11px;color:rgba(212,169,106,0.3);letter-spacing:1px;">
            © @DateTime.Now.Year Coffee Shop
        </div>
    </div>

    <!-- Form panel -->
    <div class="auth-form-panel">
        <div class="auth-form-eyebrow">Password Reset</div>
        <h1 class="auth-form-title">Reset <em>Password</em></h1>
        <p class="auth-form-sub">Enter your email address and we'll send you a link to reset your password.</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="af-validation-summary"></div>

            <div class="af-group">
                <label class="af-label" asp-for="Input.Email">Email Address</label>
                <div class="af-input-wrap">
                    <i class="fas fa-envelope af-input-icon"></i>
                    <input asp-for="Input.Email" class="af-input" autocomplete="username" placeholder="your@email.com">
                </div>
                <span asp-validation-for="Input.Email" class="af-validation"></span>
            </div>

            <button type="submit" class="af-submit">
                <i class="fas fa-paper-plane"></i> Send Reset Link
            </button>
        </form>

        <div class="af-links">
            <span>
                Remember your password?
                <a asp-area="Identity" asp-page="/Account/Login">Sign in</a>
            </span>
            <a asp-area="Identity" asp-page="/Account/Register">Create an account</a>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
