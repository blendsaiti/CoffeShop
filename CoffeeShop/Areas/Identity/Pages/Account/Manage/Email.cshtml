@page
@model EmailModel
@{
    ViewData["Title"] = "Manage Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --espresso: #1c0f08;
        --caramel: #b5752a;
        --latte: #d4a96a;
        --cream: #f5ede0;
        --foam: #faf6f0;
        --bg: #f2ede8;
        --surface: #ffffff;
        --border: rgba(181,117,42,0.13);
        --muted: #7a6a5a;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        background: var(--bg);
    }

    .manage-page {
        padding: 36px 0 64px;
    }

    .manage-layout {
        display: grid;
        grid-template-columns: 210px 1fr;
        gap: 24px;
        align-items: start;
    }

    @@media(max-width:768px) {
        .manage-layout {
            grid-template-columns: 1fr;
        }
    }

    .manage-eyebrow {
        font-size: 10px;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--caramel);
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .manage-eyebrow::before {
            content: '';
            display: block;
            width: 16px;
            height: 1px;
            background: var(--caramel);
        }

    .manage-title {
        font-family: 'Playfair Display',serif;
        font-size: 26px;
        font-weight: 700;
        color: var(--espresso);
        margin: 0 0 24px;
    }

        .manage-title em {
            font-style: italic;
            color: var(--caramel);
        }

    .manage-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 3px;
        overflow: hidden;
        margin-bottom: 20px;
    }

    .manage-panel-header {
        padding: 14px 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 9px;
    }

    .manage-panel-icon {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 1px solid rgba(181,117,42,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--caramel);
        font-size: 11px;
        flex-shrink: 0;
    }

    .manage-panel-title {
        font-family: 'Playfair Display',serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--espresso);
    }

    .manage-panel-body {
        padding: 24px;
    }

    .mf-group {
        margin-bottom: 18px;
    }

    .mf-label {
        display: block;
        font-size: 10px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 7px;
        font-weight: 500;
    }

    .mf-input {
        width: 100%;
        background: var(--foam);
        border: 1px solid rgba(181,117,42,0.18);
        border-radius: 2px;
        padding: 11px 13px;
        font-family: 'DM Sans',sans-serif;
        font-size: 14px;
        color: var(--espresso);
        outline: none;
        transition: border-color 0.2s;
    }

        .mf-input:focus {
            border-color: var(--caramel);
            box-shadow: 0 0 0 3px rgba(181,117,42,0.08);
        }

        .mf-input:disabled {
            background: rgba(122,106,90,0.06);
            color: var(--muted);
            cursor: not-allowed;
        }

    .mf-validation {
        font-size: 11px;
        color: #c0392b;
        margin-top: 4px;
        display: block;
    }

    .mf-validation-summary {
        background: rgba(192,57,43,0.06);
        border: 1px solid rgba(192,57,43,0.2);
        border-radius: 2px;
        padding: 10px 14px;
        margin-bottom: 18px;
        font-size: 13px;
        color: #c0392b;
    }

    .mf-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 11px 24px;
        border-radius: 2px;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans',sans-serif;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.18s;
    }

    .mf-btn-primary {
        background: var(--espresso);
        color: var(--cream);
    }

        .mf-btn-primary:hover {
            background: var(--caramel);
            color: white;
        }

    .mf-alert {
        display: flex;
        align-items: flex-start;
        gap: 9px;
        padding: 11px 14px;
        border-radius: 2px;
        margin-bottom: 20px;
        font-size: 13px;
    }

        .mf-alert.success {
            background: rgba(46,125,50,0.07);
            border: 1px solid rgba(46,125,50,0.2);
            color: #2e7d32;
        }

        .mf-alert.danger {
            background: rgba(192,57,43,0.07);
            border: 1px solid rgba(192,57,43,0.2);
            color: #c0392b;
        }

    .mf-close {
        background: none;
        border: none;
        cursor: pointer;
        margin-left: auto;
        color: inherit;
        opacity: 0.6;
        font-size: 14px;
        padding: 0;
    }

    .mf-hint {
        font-size: 11px;
        color: var(--muted);
        margin-top: 5px;
    }

    .email-verified-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 9px;
        border-radius: 2px;
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        background: rgba(46,125,50,0.08);
        color: #2e7d32;
        border: 1px solid rgba(46,125,50,0.2);
        margin-left: 8px;
    }
</style>

<div class="manage-page">
    <div class="container">
        <div class="manage-layout">

            <aside>
                <partial name="_ManageNav" />
            </aside>

            <main>
                <div class="manage-eyebrow">Account Settings</div>
                <h1 class="manage-title">Manage <em>Email</em></h1>

                <partial name="_StatusMessage" model="Model.StatusMessage" />

                <div class="manage-panel">
                    <div class="manage-panel-header">
                        <div class="manage-panel-icon"><i class="fas fa-envelope"></i></div>
                        <span class="manage-panel-title">Email Address</span>
                    </div>
                    <div class="manage-panel-body">
                        <form id="email-form" method="post">
                            <div asp-validation-summary="ModelOnly" class="mf-validation-summary"></div>

                            <div class="mf-group">
                                <label class="mf-label" asp-for="Email">
                                    Current Email
                                    @if (Model.EmailConfirmed)
                                    {
                                        <span class="email-verified-badge"><i class="fas fa-check" style="font-size:8px;"></i> Verified</span>
                                    }
                                </label>
                                <input asp-for="Email" class="mf-input" disabled>
                                @if (!Model.EmailConfirmed)
                                {
                                    <span class="mf-hint" style="color:#b5752a;">
                                        <i class="fas fa-exclamation-triangle" style="font-size:10px;"></i>
                                        Your email is not verified.
                                    </span>
                                }
                            </div>

                            <div class="mf-group">
                                <label class="mf-label" asp-for="Input.NewEmail">New Email Address</label>
                                <input asp-for="Input.NewEmail" class="mf-input" placeholder="new@email.com">
                                <span asp-validation-for="Input.NewEmail" class="mf-validation"></span>
                            </div>

                            <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="mf-btn mf-btn-primary">
                                <i class="fas fa-envelope"></i> Change Email
                            </button>
                        </form>
                    </div>
                </div>
            </main>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
