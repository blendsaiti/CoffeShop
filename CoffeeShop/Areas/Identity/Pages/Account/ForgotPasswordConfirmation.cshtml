@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Check Your Email";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --espresso: #1c0f08;
        --caramel: #b5752a;
        --latte: #d4a96a;
        --cream: #f5ede0;
        --foam: #faf6f0;
        --muted: #7a6a5a;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        background: var(--foam);
    }

    .confirm-page {
        min-height: calc(100vh - 68px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
        font-family: 'DM Sans', sans-serif;
    }

    .confirm-card {
        background: white;
        border: 1px solid rgba(181,117,42,0.13);
        border-radius: 3px;
        overflow: hidden;
        width: 100%;
        max-width: 480px;
        text-align: center;
    }

    .confirm-card-top {
        background: var(--espresso);
        padding: 36px 32px 28px;
        position: relative;
        overflow: hidden;
    }

        .confirm-card-top::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='20' cy='20' r='1' fill='%23b5752a' fill-opacity='0.09'/%3E%3C/svg%3E");
        }

    .confirm-icon-ring {
        position: relative;
        z-index: 1;
        width: 72px;
        height: 72px;
        border-radius: 50%;
        border: 1px solid rgba(181,117,42,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        animation: pop-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

        .confirm-icon-ring::before {
            content: '';
            position: absolute;
            inset: -8px;
            border-radius: 50%;
            border: 1px solid rgba(181,117,42,0.12);
        }

        .confirm-icon-ring i {
            font-size: 28px;
            color: var(--latte);
        }

    @@keyframes pop-in {
        from {
            transform: scale(0.6);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .confirm-card-top h1 {
        position: relative;
        z-index: 1;
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        font-weight: 700;
        color: var(--cream);
        margin: 0;
    }

        .confirm-card-top h1 em {
            font-style: italic;
            color: var(--latte);
        }

    .confirm-card-body {
        padding: 28px 32px 32px;
    }

        .confirm-card-body p {
            font-size: 14px;
            color: var(--muted);
            line-height: 1.65;
            margin: 0 0 20px;
        }

    .confirm-steps {
        background: rgba(181,117,42,0.04);
        border: 1px solid rgba(181,117,42,0.1);
        border-radius: 2px;
        padding: 16px 20px;
        margin-bottom: 24px;
        text-align: left;
    }

    .confirm-steps-title {
        font-size: 10px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--caramel);
        margin-bottom: 10px;
        font-weight: 500;
    }

    .confirm-step {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        font-size: 13px;
        color: var(--muted);
        margin-bottom: 8px;
    }

        .confirm-step:last-child {
            margin-bottom: 0;
        }

    .confirm-step-num {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--espresso);
        color: var(--latte);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .confirm-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .confirm-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: 2px;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.18s;
    }

    .confirm-btn-primary {
        background: var(--espresso);
        color: var(--cream);
    }

        .confirm-btn-primary:hover {
            background: var(--caramel);
            color: white;
        }

    .confirm-btn-ghost {
        background: transparent;
        border: 1px solid rgba(181,117,42,0.2);
        color: var(--caramel);
    }

        .confirm-btn-ghost:hover {
            background: var(--caramel);
            color: white;
        }
</style>

<div class="confirm-page">
    <div class="confirm-card">

        <div class="confirm-card-top">
            <div class="confirm-icon-ring">
                <i class="fas fa-envelope-open-text"></i>
            </div>
            <h1>Check your <em>Email</em></h1>
        </div>

        <div class="confirm-card-body">
            <p>
                If an account exists for that email address, we've sent a password reset link.
                Please check your inbox — it may take a minute to arrive.
            </p>

            <div class="confirm-steps">
                <div class="confirm-steps-title">What to do next</div>
                <div class="confirm-step">
                    <div class="confirm-step-num">1</div>
                    <span>Open the email from Coffee Shop in your inbox.</span>
                </div>
                <div class="confirm-step">
                    <div class="confirm-step-num">2</div>
                    <span>Click the reset link — it's valid for 24 hours.</span>
                </div>
                <div class="confirm-step">
                    <div class="confirm-step-num">3</div>
                    <span>Create a new password and sign back in.</span>
                </div>
            </div>

            <div class="confirm-actions">
                <a asp-area="Identity" asp-page="/Account/Login" class="confirm-btn confirm-btn-primary">
                    <i class="fas fa-sign-in-alt"></i> Back to Sign In
                </a>
                <a asp-area="Identity" asp-page="/Account/ForgotPassword" class="confirm-btn confirm-btn-ghost">
                    <i class="fas fa-redo"></i> Try a Different Email
                </a>
            </div>
        </div>

    </div>
</div>
